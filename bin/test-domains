#!/bin/sh
set -euf

## https://github.com/sixarm/unix-shell-script-kit

err() { >&2 printf %s\\n "Error: ${*}"; }

directory_exists_or_err() { test -d "$1" || err "Directory should exist: $1"; }
file_exists_or_err() { test -f "$1" || err "File should exist: $1"; }
file_not_empty_or_err() { file_exists_or_err "$1" && test -f "$1" || err "File should be not empty: $1"; }
symlink_exists_or_err() { test -h "$1" || err "Symlink should exist: $1"; }

## Main

top="$(git rev-parse --show-toplevel)"

ai_exists_or_err() (
    dir="$1"
    directory_exists_or_err "$dir"
    file_not_empty_or_err "$dir/index.md"
    symlink_exists_or_err "$dir/README.md"
    file_not_empty_or_err "$dir/AGENTS.md"
    file_not_empty_or_err "$dir/CLAUDE.md"
    file_not_empty_or_err "$dir/plan.md"
    file_not_empty_or_err "$dir/tasks.md"
)

for dir in $(find "$top/domains" -type d -depth 1 -not -name '.*' -not -name 'bin' | sort); do
    ai_exists_or_err "$dir"
    directory_exists_or_err "$dir/topics"
    directory_exists_or_err "$dir/ubiquitous-language"
    file_not_empty_or_err "$dir/ubiquitous-language/index.md"
    symlink_exists_or_err "$dir/ubiquitous-language/README.md"
done
